#!/usr/bin/env bash
set -euo pipefail

source "$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)/lib/common.sh"

if [[ ! -s "$SECRETS_ROOT/cloudflared.env" ]]; then
  printf 'Create %s/cloudflared.env from env/cloudflared.env.example before deploying the tunnel.\n' "$SECRETS_ROOT" >&2
  exit 1
fi

compose_pull cloudflared
compose_up cloudflared
