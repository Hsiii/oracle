#!/usr/bin/env bash
set -euo pipefail

source "$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)/lib/common.sh"

if [ ! -f "$PLATFORM_ROOT/artifacts/homepage/server.js" ]; then
  printf 'Expected homepage artifact at %s/artifacts/homepage/server.js\n' "$PLATFORM_ROOT" >&2
  exit 1
fi

compose_pull homepage
compose_up homepage
